import 'dart:io';
import 'dart:typed_data';
import 'package:flutter/material.dart';
import 'package:camera/camera.dart';
import 'package:image_picker/image_picker.dart';
import 'package:image_gallery_saver_plus/image_gallery_saver_plus.dart'; // ✅ صحیح درآمد
import 'package:permission_handler/permission_handler.dart';
import 'package:image/image.dart' as img;

void main() async {
  WidgetsFlutterBinding.ensureInitialized();
  final cameras = await availableCameras();
  runApp(FilterApp(cameras: cameras));
}

class FilterApp extends StatelessWidget {
  final List<CameraDescription> cameras;
  const FilterApp({super.key, required this.cameras});

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: 'Pro Camera',
      theme: ThemeData.dark().copyWith(
        colorScheme: ColorScheme.fromSeed(seedColor: Colors.blue, brightness: Brightness.dark),
        useMaterial3: true,
      ),
      home: CameraScreen(cameras: cameras),
    );
  }
}

class CameraScreen extends StatefulWidget {
  final List<CameraDescription> cameras;
  const CameraScreen({super.key, required this.cameras});

  @override
  State<CameraScreen> createState() => _CameraScreenState();
}

class _CameraScreenState extends State<CameraScreen> {
  CameraController? _controller;
  bool _isCameraReady = false;
  int _currentCameraIndex = 0;
  double _zoomLevel = 0.0;
  bool _nightVisionEnabled = false;
  bool _isSaving = false;
  double _maxZoom = 1.0; // ✅ متغیر محفوظ کرنے کے لیے

  @override
  void initState() {
    super.initState();
    _initCamera();
  }

  Future<void> _initCamera() async {
    // ... کیمرے کی اجازت اور دستیابی کے لیے وہی کوڈ ...
    final status = await Permission.camera.request();
    if (!status.isGranted) {
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          const SnackBar(content: Text('Camera permission required')),
        );
      }
      return;
    }
    if (widget.cameras.isEmpty) {
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          const SnackBar(content: Text('No camera found')),
        );
      }
      return;
    }
    int index = _currentCameraIndex;
    if (index >= widget.cameras.length) index = 0;
    final camera = widget.cameras[index];
    _controller = CameraController(camera, ResolutionPreset.medium, enableAudio: false);
    try {
      await _controller!.initialize();
      // ✅ maxZoomLevel کو محفوظ کرنے کا درست طریقہ
      _maxZoom = _controller!.value.maxZoomLevel;
      if (_maxZoom > 1.0) {
        await _controller!.setZoomLevel(_zoomLevel);
      }
      if (mounted) {
        setState(() {
          _isCameraReady = true;
        });
      }
    } catch (e) {
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(content: Text('Camera error: $e')),
        );
      }
    }
  }

  // ... _toggleCamera, _takePictureAndSave, _applyGreenFilter (تبدیل کے بغیر) ...

  // ✅ تبدیل شدہ _applyGreenFilter (مطابقت پذیر)
  Future<Uint8List> _applyGreenFilter(Uint8List imageBytes) async {
    img.Image? image = img.decodeImage(imageBytes);
    if (image == null) return imageBytes;

    // ✅ نئے `image` پیکیج کے مطابق پکسلز پر iterate کرنے کا درست طریقہ
    for (int i = 0; i < image.width; i++) {
      for (int j = 0; j < image.height; j++) {
        final pixel = image.getPixel(i, j);
        final r = pixel.r;
        final g = pixel.g;
        final b = pixel.b;
        int newR = (r * 0.3).toInt();
        int newG = (g * 1.5).toInt();
        int newB = (b * 0.3).toInt();
        image.setPixel(i, j, img.ColorRgb8(newR.clamp(0, 255), newG.clamp(0, 255), newB.clamp(0, 255)));
      }
    }
    return Uint8List.fromList(img.encodePng(image));
  }

  // ✅ تبدیل شدہ _pickFromGallery (اس میں اب GallerySaver استعمال نہیں ہوگا)
  Future<void> _pickFromGallery() async {
    final status = await Permission.photos.request();
    if (!status.isGranted) {
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(content: Text('Storage permission required')),
      );
      return;
    }
    final picker = ImagePicker();
    final picked = await picker.pickImage(source: ImageSource.gallery);
    if (picked != null) {
      final bytes = await picked.readAsBytes();
      // ✅ ڈائریکٹ save کرنے کی بجائے صارف کو "Save to Gallery" کا آپشن دیں
      bool? shouldSave = await showDialog<bool>(
        context: context,
        builder: (context) => AlertDialog(
          title: const Text('Save to Gallery?'),
          content: const Text('Do you want to save this image from the gallery?'),
          actions: [
            TextButton(onPressed: () => Navigator.pop(context, false), child: const Text('No')),
            TextButton(onPressed: () => Navigator.pop(context, true), child: const Text('Yes')),
          ],
        ),
      );

      if (shouldSave == true) {
        final result = await ImageGallerySaverPlus.saveImage(bytes);
        if (result['isSuccess'] == true) {
          if (mounted) {
            ScaffoldMessenger.of(context).showSnackBar(
              const SnackBar(content: Text('Image saved to gallery!')),
            );
          }
        } else {
          throw Exception('Failed to save image');
        }
      }
    }
  }

  // ✅ تبدیل شدہ _takePictureAndSave (مکمل طور پر نئے سرے سے لکھا گیا)
  Future<void> _takePictureAndSave() async {
    if (!_isCameraReady || _controller == null) {
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(content: Text('Camera not ready')),
      );
      return;
    }
    setState(() => _isSaving = true);
    try {
      final XFile rawImage = await _controller!.takePicture();
      final bytes = await rawImage.readAsBytes();
      Uint8List finalBytes;
      if (_nightVisionEnabled) {
        finalBytes = await _applyGreenFilter(bytes);
      } else {
        finalBytes = bytes;
      }
      final result = await ImageGallerySaverPlus.saveImage(finalBytes);
      if (result['isSuccess'] == true) {
        if (mounted) {
          ScaffoldMessenger.of(context).showSnackBar(
            const SnackBar(content: Text('Image saved to gallery!')),
          );
        }
      } else {
        throw Exception('Failed to save image');
      }
    } catch (e) {
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(content: Text('Error: $e')),
        );
      }
    } finally {
      if (mounted) setState(() => _isSaving = false);
    }
  }

  // ... dispose اور build method (جن میں Slider وغیرہ کے لیے _maxZoom استعمال ہوگا) ...
}
