<?xml version="1.0" encoding="utf-8"?>
<resources
    <style name="Theme.App" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/neon_cyan</item>
        <item name="colorPrimaryDark">@color/black</item>
        <item name="colorAccent">@color/neon_pink</item>
        <item name="android:statusBarColor">@color/black</item>
    </style>

    <style name="ActionButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TabButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/neon_cyan</item>
        <item name="android:textStyle">bold</item>
        <item name="rippleColor">#3300FFCC</item>
    </style>

    <style name="BuildButton" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/neon_cyan</item>
        <item name="android:textColor">@color/black</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="GlassCard">
        <item name="cardBackgroundColor">#1AFFFFFF</item>
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">16dp</item>
    </style>
</resources>
