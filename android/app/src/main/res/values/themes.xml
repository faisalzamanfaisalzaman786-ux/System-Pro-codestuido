<resources>
    <style name="Theme.SystemPro" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        </style>

    <style name="ActionButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:background">@drawable/custom_button_wrapper</item>
        <item name="android:textColor">@color/neon_cyan</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TabButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="BuildButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:layout_margin">12dp</item>
        <item name="android:background">@drawable/custom_button_wrapper</item>
        <item name="android:backgroundTint">@color/neon_green</item>
        <item name="android:textColor">#000000</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
